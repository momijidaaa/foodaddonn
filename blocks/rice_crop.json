{
  "format_version": "1.20.0",
  "minecraft:block": {
    "description": {
      "identifier": "mc:rice_crop",
      "states": {
        "mc:crop_age": [0, 1, 2, 3]
      }
    },
    "components": {
      "minecraft:on_step_on": {},
      "minecraft:on_step_off": {},
      // --- 当たり判定の設定（これで宙に浮くのを防ぐ） ---
      "minecraft:collision_box": {
        "origin": [-4, 0, -4],
        "size": [8, 2, 8]
      },
      "minecraft:selection_box": {
        "origin": [-4, 0, -4],
        "size": [8, 2, 8]
      },
      // --- 基本設定 ---
      "minecraft:geometry": "minecraft:geometry.crop",
      "minecraft:material_instances": {
        "*": {
          "texture": "rice_crop_stage_0",
          "render_method": "alpha_test",
          "face_dimming": false
        }
      },
      "minecraft:loot": "loot_tables/blocks/rice_crop.json",
      // --- 成長のロジック ---
      "minecraft:queued_ticking": {
        "looping": true,
        "interval_range": [20, 40],
        "on_tick": {
          "event": "mc:grow_tick",
          "target": "self"
        }
      },
      // --- 骨粉（肥料）の設定 ---
      "minecraft:on_interact": {
        "condition": "query.get_equipped_item_name('main_hand') == 'bone_meal'",
        "event": "mc:fertilize_crop"
      }
    },
    "events": {
      "mc:grow_tick": {
        "randomize": [
          {
            "weight": 1,
            "set_block_state": {
              "mc:crop_age": "query.block_state('mc:crop_age') < 3 ? query.block_state('mc:crop_age') + 1 : 3"
            }
          },
          { "weight": 2 } // 成長しない確率
        ]
      },
      "mc:fertilize_crop": {
        "sequence": [
          {
            "decrement_stack": {},
            "run_command": { "command": ["particle minecraft:crop_growth_emitter ~ ~ ~"] },
            "set_block_state": {
              "mc:crop_age": "query.block_state('mc:crop_age') < 3 ? query.block_state('mc:crop_age') + 1 : 3"
            }
          }
        ]
      }
    },
    "permutations": [
      {
        "condition": "query.block_state('mc:crop_age') == 0",
        "components": { "minecraft:material_instances": { "*": { "texture": "rice_crop_stage_0" } } }
      },
      {
        "condition": "query.block_state('mc:crop_age') == 1",
        "components": { "minecraft:material_instances": { "*": { "texture": "rice_crop_stage_1" } } }
      },
      {
        "condition": "query.block_state('mc:crop_age') == 2",
        "components": { "minecraft:material_instances": { "*": { "texture": "rice_crop_stage_2" } } }
      },
      {
        "condition": "query.block_state('mc:crop_age') == 3",
        "components": { "minecraft:material_instances": { "*": { "texture": "rice_crop_stage_3" } } }
      }
    ]
  }
}

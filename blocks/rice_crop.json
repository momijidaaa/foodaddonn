{
  "format_version": "1.20.0",
  "minecraft:block": {
    "description": {
      "identifier": "mc:rice_crop_stage_0",
      "states": {
        "mc:crop_age": [0, 1, 2, 3]
      }
    },

    "components": {
      "minecraft:collision_box": false,

      "minecraft:material_instances": {
        "*": {
          "render_method": "alpha_test"
        }
      },

      "minecraft:loot": "loot_tables/blocks/rice_crop.json"
    },

    "permutations": [
      {
        "condition": "query.block_state('mc:crop_age') == 0",
        "components": {
          "minecraft:material_instances": {
            "*": { "texture": "rice_crop_stage_0" }
          }
        }
      },
      {
        "condition": "query.block_state('mc:crop_age') == 1",
        "components": {
          "minecraft:material_instances": {
            "*": { "texture": "rice_crop_stage_1" }
          }
        }
      },
      {
        "condition": "query.block_state('mc:crop_age') == 2",
        "components": {
          "minecraft:material_instances": {
            "*": { "texture": "rice_crop_stage_2" }
          }
        }
      },
      {
        "condition": "query.block_state('mc:crop_age') == 3",
        "components": {
          "minecraft:material_instances": {
            "*": { "texture": "rice_crop_stage_3" }
          }
        }
      }
    ]
  }
}
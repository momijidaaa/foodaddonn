{
  "format_version": "1.20.0",
  "minecraft:block": {
    "description": {
      "identifier": "mc:rice_crop",
      "states": {
        "mc:crop_age": [0, 1, 2, 3]
      }
    },
    "components": {
      "minecraft:block_light_filter": 0,
      "minecraft:destructible_by_mining": {
        "seconds_to_destroy": 0
      },
      "minecraft:destructible_by_explosion": {
        "explosion_resistance": 0
      },
      "minecraft:collision_box": {
        "origin": [-4, 0, -4],
        "size": [8, 1, 8]
      },
      "minecraft:selection_box": {
        "origin": [-4, 0, -4],
        "size": [8, 4, 8]
      },
      "minecraft:geometry": "minecraft:geometry.crop",
      "minecraft:material_instances": {
        "*": {
          "texture": "rice_crop_stage_0",
          "render_method": "alpha_test",
          "face_dimming": false
        }
      },
      "minecraft:loot": "loot_tables/blocks/rice_crop.json",
      "minecraft:queued_ticking": {
        "looping": true,
        "interval_range": [20, 60],
        "on_tick": {
          "event": "mc:grow_tick",
          "target": "self"
        }
      },
      "minecraft:on_interact": {
        "condition": "query.get_equipped_item_name('main_hand') == 'bone_meal'",
        "event": "mc:fertilize_crop"
      }
    },
    "events": {
      "mc:grow_tick": {
        "randomize": [
          {
            "weight": 1,
            "set_block_state": {
              "mc:crop_age": "query.block_state('mc:crop_age') < 3 ? query.block_state('mc:crop_age') + 1 : 3"
            }
          },
          {
            "weight": 2
          }
        ]
      },
      "mc:fertilize_crop": {
        "sequence": [
          {
            "decrement_stack": {},
            "run_command": {
              "command": [
                "particle minecraft:crop_growth_emitter ~ ~ ~"
              ]
            },
            "set_block_state": {
              "mc:crop_age": "query.block_state('mc:crop_age') < 3 ? query.block_state('mc:crop_age') + 1 : 3"
            }
          }
        ]
      }
    },
    "permutations": [
      {
        "condition": "query.block_state('mc:crop_age') == 0",
        "components": {
          "minecraft:material_instances": {
            "*": {
              "texture": "rice_crop_stage_0"
            }
          }
        }
      },
      {
        "condition": "query.block_state('mc:crop_age') == 1",
        "components": {
          "minecraft:material_instances": {
            "*": {
              "texture": "rice_crop_stage_1"
            }
          }
        }
      },
      {
        "condition": "query.block_state('mc:crop_age') == 2",
        "components": {
          "minecraft:material_instances": {
            "*": {
              "texture": "rice_crop_stage_2"
            }
          }
        }
      },
      {
        "condition": "query.block_state('mc:crop_age') == 3",
        "components": {
          "minecraft:material_instances": {
            "*": {
              "texture": "rice_crop_stage_3"
            }
          }
        }
      }
    ]
  }
}
